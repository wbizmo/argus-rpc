{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "outDir": "./dist",
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src",
    "tests",
    "examples",
    "benchmarks"
  ]
}
